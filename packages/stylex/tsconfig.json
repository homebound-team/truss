{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "build/",
    "baseUrl": ".",
    "paths": {
      "@homebound/truss-stylex": ["./src/index.ts"]
    }
  },
  "include": ["./src"]
}
