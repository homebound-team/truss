{
  "name": "@homebound/truss",
  "version": "2.19.0",
  "type": "module",
  "main": "build/index.js",
  "bin": "cli.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./plugin": {
      "types": "./build/plugin/index.d.ts",
      "import": "./build/plugin/index.js",
      "default": "./build/plugin/index.js"
    },
    "./runtime": {
      "types": "./build/runtime.d.ts",
      "import": "./build/runtime.js",
      "default": "./build/runtime.js"
    },
    "./vitest": {
      "types": "./build/vitest.d.ts",
      "import": "./build/vitest.js",
      "default": "./build/vitest.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest --run"
  },
  "license": "ISC",
