    "csstype": "^3.2.3",
    "jiti": "^2.6.1",
    "ts-poet": "^6.12.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@homebound/tsconfig": "^1.1.1",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
