{
  "extends": "../../tsconfig.package.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "sourceMap": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "build/",
    "paths": {
      "src": ["./src"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["./src"]
}
